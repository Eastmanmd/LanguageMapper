# Supabase project credentials (Dashboard > Settings > API).
# The URL and anon key are safe to expose in the client bundle.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, used by `npm run sync-data`.
# NEVER commit the real value or expose it to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
